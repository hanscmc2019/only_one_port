# ════════════════════════════════════════════════════════════════
#  .env.example — PLANTILLA de documentación. NO se usa en ejecución.
#
#  Copia este archivo a .env y rellena los valores reales:
#      cp .env.example .env
#  El .env real está gitignored; este .example sí se versiona para
#  documentar qué variables necesita el stack.
#
#  Organizado por servicio. Arriba el CORE (Fase 1: nginx + postgres +
#  backend); al final el bloque del BOT (Fase 2: evolution + redis + n8n),
#  inerte mientras esos servicios estén apagados/comentados en el compose.
# ════════════════════════════════════════════════════════════════


# ╔══════════════════════════════════════════════════════════════╗
# ║  STACK — identidad y puertos del host (compartido)            ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Identidad del stack (multi-cliente) ──────────────────────────
# Prefijo único por cliente para contenedores, red y volúmenes.
# Para correr varios stacks en un mismo servidor, dale a cada cliente
# un CLIENT_NAME distinto (y puertos distintos abajo).
CLIENT_NAME=cliente_demo

# Zona horaria del stack — la consumen postgres (timezone del servidor) y
# backend (reloj del contenedor). Define en qué hora se guardan/muestran las
# fechas (orders, inventario, chat). Default America/Lima (UTC-5 fijo).
TZ=America/Lima

# ── Puertos publicados en el host (únicos por cliente) ───────────
WEB_PORT=8090            # sitio público (nginx)
EVOLUTION_PORT=8080      # API de Evolution (bind a 127.0.0.1) — Fase 2 (bot)
N8N_PORT=5678            # editor de n8n (bind a 127.0.0.1) — Fase 2 (bot)


# ╔══════════════════════════════════════════════════════════════╗
# ║  POSTGRES — BD del e-commerce (schemas: public + tienda + n8n) ║
# ╚══════════════════════════════════════════════════════════════╝
# Lo consumen: postgres (crea la BD), backend (Django) y n8n (schema n8n).
POSTGRES_DB=ecommerce_db
POSTGRES_USER=ecommerce_user
POSTGRES_PASSWORD=cambia-este-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432


# ╔══════════════════════════════════════════════════════════════╗
# ║  BACKEND — API Django                                         ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Django ───────────────────────────────────────────────────────
# Genera una SECRET_KEY nueva (ver CLAUDE.md). Escapa cada '$' como '$$'.
DEBUG=False
SECRET_KEY=cambia-esta-clave-y-escapa-los-$$-como-$$$$
ALLOWED_HOSTS=localhost,127.0.0.1,backend
# Acceso por IP/dominio público (NAT): solo el host, SIN esquema/puerto/ruta.
# settings.py lo suma solo a ALLOWED_HOSTS y a CORS/CSRF usando WEB_PORT
# (p. ej. PUBLIC_HOST=38.25.74.14 → permite http://38.25.74.14:$WEB_PORT). Vacío = sin NAT.
PUBLIC_HOST=
# CORS_ALLOWED_ORIGINS / CSRF_TRUSTED_ORIGINS: por defecto settings.py los deriva
# de WEB_PORT (http://localhost:$WEB_PORT y http://127.0.0.1:$WEB_PORT), así que
# cambiar WEB_PORT basta. Descoméntalos solo para sobreescribir (p. ej. el dominio
# real en producción):
#CORS_ALLOWED_ORIGINS=https://tu-dominio.com
#CSRF_TRUSTED_ORIGINS=https://tu-dominio.com

# ── Negocio ──────────────────────────────────────────────────────
# Número de WhatsApp para el checkout (enlace wa.me; NO usa Evolution).
WHATSAPP_PHONE=519XXXXXXXX
# Tipo de negocio: "variants" (ropa: talla/color) o "simple" (cosméticos).
# Controla el selector de variantes en la tienda y la etiqueta del 2º precio.
# Lo consumen backend (/api/config) y n8n (prompt). Default simple.
STORE_TYPE=simple

# ── Usuarios sembrados (entrypoint.sh) ───────────────────────────
# Credenciales iniciales por rol para un cliente nuevo. La contraseña solo
# se aplica al crear el usuario (primer arranque con la BD vacía).
SEED_SUPERADMIN_USERNAME=superadmin
SEED_SUPERADMIN_EMAIL=admin@tudominio.com
SEED_SUPERADMIN_PASSWORD=cambia-esta-clave
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@tudominio.com
SEED_ADMIN_PASSWORD=cambia-esta-clave
SEED_CUSTOMER_USERNAME=cliente
SEED_CUSTOMER_EMAIL=cliente@tudominio.com
SEED_CUSTOMER_PASSWORD=cambia-esta-clave


# ════════════════════════════════════════════════════════════════
# ║                                                                ║
# ║   BOT DE WHATSAPP — Fase 2                                     ║
# ║   Variables de evolution-api / evolution-postgres / n8n.       ║
# ║   Inertes mientras esos servicios estén apagados o comentados  ║
# ║   en docker-compose.yml.                                       ║
# ║                                                                ║
# ════════════════════════════════════════════════════════════════

# ── Evolution API (gateway de WhatsApp) ──────────────────────────
# EVOLUTION_API_KEY es la única clave: el compose la mapea a la
# AUTHENTICATION_API_KEY de Evolution, y el backend la reusa para que el
# Monitor de Ventas envíe mensajes de WhatsApp (settings.EVOLUTION_API_*).
EVOLUTION_API_KEY=genera-una-apikey-fuerte
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_INSTANCE=test

# ── Postgres propio de Evolution (separado del de e-commerce) ────
EVOLUTION_POSTGRES_DB=evolution_db
EVOLUTION_POSTGRES_USER=evolution_user
EVOLUTION_POSTGRES_PASSWORD=cambia-este-password

# ── n8n (motor del bot) ──────────────────────────────────────────
# Genera 32 chars aleatorios y GUÁRDALOS (sin esto no se descifran las
# credenciales de n8n tras recrear el volumen):
#   openssl rand -hex 16
N8N_ENCRYPTION_KEY=genera-32-caracteres-aleatorios
N8N_WEBHOOK_URL=http://localhost:5678/

# API key de OpenRouter para el agente LLM del bot
OPENROUTER_API_KEY=__SET_OPENROUTER_API_KEY__

# Owner de n8n (auto-creado; login fijo, sin formulario manual). Pass: min 8, 1 may, 1 num.
N8N_OWNER_EMAIL=admin@n8n.local
N8N_OWNER_PASSWORD=Admin1234
